# Environment Configuration Template
# Copy to .env.prod or .env.dev and update values

# ============================================
# General Configuration
# ============================================
NODE_ENV=production
SERVICE_PORT=3000
LOG_LEVEL=info

# ============================================
# Frontend Configuration
# ============================================
REACT_APP_API_BASE_URL=http://localhost:5001
REACT_APP_USER_API_URL=http://localhost:5002
REACT_APP_ENVIRONMENT=production
REACT_APP_DEBUG=false

# ============================================
# Content Service Configuration
# ============================================
CONTENT_SERVICE_PORT=5001
CONTENT_SERVICE_NAME=content-service
CONTENT_DB_HOST=localhost
CONTENT_DB_PORT=27017
CONTENT_DB_NAME=content_db
CONTENT_DB_USER=admin
CONTENT_DB_PASSWORD=changeme

# ============================================
# User Service Configuration
# ============================================
USER_SERVICE_PORT=5002
USER_SERVICE_NAME=user-service
USER_DB_HOST=localhost
USER_DB_PORT=27017
USER_DB_NAME=user_db
USER_DB_USER=admin
USER_DB_PASSWORD=changeme

# ============================================
# Redis Cache Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ============================================
# Security Configuration
# ============================================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=7d
API_KEY=your-api-key-here
CORS_ORIGIN=http://localhost:3000

# ============================================
# Docker Configuration
# ============================================
DOCKER_USER=altaf7258
DOCKER_REGISTRY=docker.io
REGISTRY_PASSWORD=your-docker-password

# ============================================
# Jenkins Configuration
# ============================================
JENKINS_URL=http://localhost:8080
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=your-sonarqube-token

# ============================================
# Deployment Configuration
# ============================================
DEPLOYMENT_DIR=C:\deployment
BACKUP_DIR=C:\backups
ENVIRONMENT=production

# ============================================
# Monitoring & Logging
# ============================================
ELK_HOST=localhost
ELK_PORT=9200
LOG_AGGREGATION_ENABLED=true
METRICS_COLLECTION_ENABLED=true
SENTRY_DSN=https://your-sentry-dsn

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ============================================
# External APIs
# ============================================
PAYMENT_API_URL=https://api.payment-provider.com
PAYMENT_API_KEY=your-api-key
NOTIFICATION_API_URL=https://api.notification-provider.com
NOTIFICATION_API_KEY=your-api-key

# ============================================
# Feature Flags
# ============================================
FEATURE_NEW_UI=true
FEATURE_ADVANCED_SEARCH=false
FEATURE_BETA_TESTING=false
MAINTENANCE_MODE=false
