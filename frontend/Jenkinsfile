// Approval added

pipeline {
    agent any
    
    environment {
        DOCKER_USER     = 'altaf7258'
        // Updated variables to clearly distinguish Production from Staging
        PROD_EC2_IP     = '13.127.220.170' 
        APP_DIR         = '/home/ubuntu/app'
        GIT_SHORT_SHA   = "${env.GIT_COMMIT ? env.GIT_COMMIT.take(7) : 'latest'}"
    }
    
    stages {
        stage('SonarQube Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    bat "docker run --rm --network=\"host\" -v %WORKSPACE%:/usr/src sonarsource/sonar-scanner-cli -Dsonar.projectKey=demo -Dsonar.sources=./frontend -Dsonar.host.url=http://127.0.0.1:9000 -Dsonar.token=%SONAR_TOKEN%"
                }
            }
        }
        
        stage("Quality Gate") {
            steps {
                script {
                    echo "Checking SonarQube Quality Gate status..."
                    try {
                        timeout(time: 5, unit: 'MINUTES') {
                            waitForQualityGate abortPipeline: true
                        }
                    } catch (Exception e) {
                        echo "Quality gate engine check bypassed or timed out. Review metrics at http://localhost:9000"
                    }
                }
            }
        }

        stage('Login to Docker Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    bat "docker login -u %USER% -p %PASS%"
                }
            }
        }

        stage('Build Frontend Application') {
            steps {
                echo "Starting Production Build for Commit: ${env.GIT_SHORT_SHA}"
                bat "docker build -t %DOCKER_USER%/demo-frontend:%GIT_SHORT_SHA% ./frontend"
                bat "docker tag %DOCKER_USER%/demo-frontend:%GIT_SHORT_SHA% %DOCKER_USER%/demo-frontend:latest"
            }
        }

        stage('Trivy Container Scan') {
            steps {
                echo "Cleaning up any old workspace cache to prevent SonarQube errors..."
                bat "if exist .trivycache rmdir /s /q .trivycache"
                
                echo "Scanning frontend image for vulnerabilities..."
                bat "docker run --rm -v //var/run/docker.sock:/var/run/docker.sock -v C:\\ProgramData\\Jenkins\\trivy_cache:/root/.cache/ aquasec/trivy:latest image --severity HIGH,CRITICAL --exit-code 0 %DOCKER_USER%/demo-frontend:%GIT_SHORT_SHA%"
            }
        }

        stage('Push to Docker Hub') {
            steps {
                bat "docker push %DOCKER_USER%/demo-frontend:%GIT_SHORT_SHA%"
                bat "docker push %DOCKER_USER%/demo-frontend:latest"
            }
        }

        stage('Gate: Approve Production Deployment') {
            steps {
                script {
                    echo "Pausing pipeline. Waiting for Production release confirmation..."
                    // Automatically aborts the build if no one acts within 2 hours
                    timeout(time: 2, unit: 'HOURS') {
                        input id: 'Proceed-To-Prod', 
                              message: "Deploy build ${env.GIT_SHORT_SHA} to Production?", 
                              ok: 'Approve & Release'
                    }
                }
            }
        }

        stage('Deploy to Production EC2') {
            steps {
                withCredentials([sshUserPrivateKey(credentialsId: 'ec2-ssh-key', keyFileVariable: 'KEY_FILE')]) {
                    bat """
                    @echo off
                    icacls "%KEY_FILE%" /inheritance:d /q
                    icacls "%KEY_FILE%" /remove "BUILTIN\\Users" /q
                    icacls "%KEY_FILE%" /remove "Authenticated Users" /q
                    icacls "%KEY_FILE%" /grant:r "%USERNAME%:(F)" /q
                    
                    echo Permissions locked down successfully. Connecting to Production EC2...
                    
                    ssh -i "%KEY_FILE%" -o StrictHostKeyChecking=no ubuntu@%PROD_EC2_IP% "cd %APP_DIR% && docker compose pull && docker compose up -d --force-recreate frontend"
                    """
                }
            }
        }
    }
    
    post {
        always {
            bat "docker logout"
        }
        success {
            echo "Production Deployment completed successfully!"
        }
        failure {
            echo "Pipeline execution failed. Check logs."
        }
        aborted {
            echo "Deployment was rejected or timed out by the operator."
        }
    }
}







