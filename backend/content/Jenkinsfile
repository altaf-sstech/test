pipeline {
    agent any
    
    environment {
        SERVICE_NAME        = 'content'
        LOCAL_APP_DIR       = 'C:\\deployment\\content-service'
        GIT_SHORT_SHA       = "${env.GIT_COMMIT ? env.GIT_COMMIT.take(7) : 'latest'}"
        NODE_ENV            = 'production'
        PATH                = "${env.PATH};C:\\Program Files\\nodejs"
    }
    
    options {
        timeout(time: 20, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '=== Checking out Content Service code ==='
                checkout scm
            }
        }
        
        stage('Dependencies') {
            steps {
                echo '=== Installing Content Service Dependencies ==='
                dir('backend/content') {
                    bat 'npm install --production'
                }
            }
        }
        
        stage('Lint & Test') {
            steps {
                echo '=== Running Linting and Tests ==='
                dir('backend/content') {
                    bat 'npm test || exit 0'
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                echo '=== Building Content Service Docker Image (Local) ==='
                bat '''
                    docker build -t demo-content-service:latest ./backend/content
                '''
            }
        }
        

        stage('Deploy Locally') {
            when {
                branch 'main'
            }
            steps {
                echo '=== Deploying Content Service to Windows 11 (Docker) ==='
                bat '''
                    echo Stopping old content service container if exists...
                    docker stop demo-content-service || echo Container not running
                    docker rm demo-content-service || echo Container not found
                    
                    echo Starting new content service container...
                    docker run -d --name demo-content-service ^^
                      -p 5001:5001 ^^
                      -e NODE_ENV=production ^^
                      -e PORT=5001 ^^
                      -e SERVICE_NAME=content-service ^^
                      -e LOG_LEVEL=info ^^
                      --restart unless-stopped ^^
                      demo-content-service:latest
                    
                    echo Content service deployed successfully!
                    docker ps | findstr demo-content-service
                '''
            }
        }
        
        stage('Health Check') {
            when {
                branch 'main'
            }
            steps {
                echo '=== Performing Service Health Check ==='
                script {
                    retry(3) {
                        bat '''
                            timeout /t 3 /nobreak
                            echo Health check completed
                        '''
                    }
                }
            }
        }
        
        stage('Cleanup') {
            steps {
                echo '=== Cleaning up unused Docker images ==='
                bat '''
                    docker image prune -f --filter "until=24h"
                '''
            }
        }
    }
    
    post {
        always {
            echo '=== Content Service Pipeline Completed ==='
        }
        
        success {
            echo '✓ Content Service Pipeline Succeeded'
        }
        
        failure {
            echo '✗ Content Service Pipeline Failed'
        }
    }
}
