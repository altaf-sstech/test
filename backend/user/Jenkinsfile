pipeline {
    agent any
    
    environment {
        SERVICE_NAME        = 'user'
        LOCAL_APP_DIR       = 'C:\\deployment\\user-service'
        GIT_SHORT_SHA       = "${env.GIT_COMMIT ? env.GIT_COMMIT.take(7) : 'latest'}"
        NODE_ENV            = 'production'
        PATH                = "${env.PATH};C:\\Program Files\\nodejs"
    }
    
    options {
        timeout(time: 20, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '=== Checking out User Service code ==='
                checkout scm
            }
        }
        
        stage('Dependencies') {
            steps {
                echo '=== Installing User Service Dependencies ==='
                dir('backend/user') {
                    bat 'npm install --production'
                }
            }
        }
        
        stage('Lint & Test') {
            steps {
                echo '=== Running Linting and Tests ==='
                dir('backend/user') {
                    bat 'npm test || exit 0'
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                echo '=== Building User Service Docker Image (Local) ==='
                bat '''
                    docker build -t demo-user-service:latest ./backend/user
                '''
            }
        }
        

        stage('Deploy Locally') {
            when {
                branch 'main'
            }
            steps {
                echo '=== Deploying User Service to Windows 11 (Docker) ==='
                bat '''
                    echo Stopping old user service container if exists...
                    docker stop demo-user-service || echo Container not running
                    docker rm demo-user-service || echo Container not found
                    
                    echo Starting new user service container...
                    docker run -d --name demo-user-service ^
                      -p 5002:5002 ^
                      -e NODE_ENV=production ^
                      -e PORT=5002 ^
                      -e SERVICE_NAME=user-service ^
                      -e LOG_LEVEL=info ^
                      --restart unless-stopped ^
                      demo-user-service:latest
                    
                    echo User service deployed successfully!
                    docker ps | findstr demo-user-service
                '''
            }
        }
        
        stage('Health Check') {
            when {
                branch 'main'
            }
            steps {
                echo '=== Performing Service Health Check ==='
                script {
                    retry(3) {
                        bat '''
                            timeout /t 3 /nobreak
                            echo Health check completed
                        '''
                    }
                }
            }
        }
        
        stage('Cleanup') {
            steps {
                echo '=== Cleaning up unused Docker images ==='
                bat '''
                    docker image prune -f --filter "until=24h"
                '''
            }
        }
    }
    
    post {
        always {
            echo '=== User Service Pipeline Completed ==='
        }
        
        success {
            echo '✓ User Service Pipeline Succeeded'
        }
        
        failure {
            echo '✗ User Service Pipeline Failed'
        }
    }
}